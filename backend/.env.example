# Server Environment
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/gym-saas?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_chars_long
JWT_EXPIRES_IN=1d

# Client URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis (Placeholder for future phases)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Cloudinary (Placeholder for future phases)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
